# Chave de API da Blackcat (https://docs.blackcatoficial.com)
# Copie este arquivo para ".env.local" e cole sua chave real ali.
# Nunca commite a chave real neste arquivo nem em nenhum arquivo versionado.
BLACKCAT_API_KEY=

# Token de API da Utmify (Dashboard Utmify → Integrações → Webhooks → Credenciais de API)
# Opcional: sem ele, o site funciona normalmente, só não notifica a Utmify sobre os pedidos.
UTMIFY_API_TOKEN=
